{
  "name": "meridian-claude-sidecar",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "bundle": "esbuild src/index.ts --bundle --platform=node --format=cjs --outfile=dist/bundle.cjs --external:@anthropic-ai/claude-agent-sdk-darwin-arm64 --external:@anthropic-ai/claude-agent-sdk-darwin-x64 --external:@anthropic-ai/claude-agent-sdk-linux-x64 --external:@anthropic-ai/claude-agent-sdk-linux-arm64 --external:@anthropic-ai/claude-agent-sdk-linux-x64-musl --external:@anthropic-ai/claude-agent-sdk-linux-arm64-musl --external:@anthropic-ai/claude-agent-sdk-win32-x64 --external:@anthropic-ai/claude-agent-sdk-win32-arm64"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.114",
    "@google-cloud/vertexai": "^1.12.0",
    "@google/generative-ai": "^0.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.0.0"
  }
}
