{
  "name": "meridian-sidecar",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "bundle": "esbuild src/index.ts --bundle --platform=node --format=cjs --outfile=dist/bundle.cjs --external:better-sqlite3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.1",
    "@langchain/anthropic": "^0.3.11",
    "@langchain/core": "^0.3.27",
    "@langchain/google-genai": "^0.1.6",
    "@langchain/langgraph": "^0.2.39",
    "@langchain/langgraph-checkpoint-sqlite": "^1.0.1",
    "@langchain/ollama": "^0.1.4",
    "better-sqlite3": "^12.9.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.0.0",
    "vitest": "^2.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
